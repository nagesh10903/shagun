# Application
APP_NAME=Shagun
APP_ENV=development
DEBUG=true
SECRET_KEY=shagun-super-secret-key-32-chars-long-or-more

# Database (MySQL)
DATABASE_URL=mysql+pymysql://nagesh:test123@192.168.1.105/shagun

# JWT
JWT_SECRET_KEY=shagun-jwt-secret-key-development
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Razorpay (Defaulting to test placeholders)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx

# CORS
CORS_ORIGINS=http://localhost:8000;

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# Notifications (stubs in v1)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@shagun.app

# Frontend URL (for invite links)
FRONTEND_URL=http://localhost:5173
